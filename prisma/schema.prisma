generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exemplo {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exemplos")
}

enum PerfilUsuario {
  ALUNO
  PROFESSOR
  ADMIN
}

enum StatusUsuario {
  PENDENTE
  ATIVO
  INATIVO
  RECUSADO
}

enum NivelEducacional {
  ENSINO_FUNDAMENTAL
  ENSINO_MEDIO
  GRADUACAO
  POS_GRADUACAO
  MESTRADO
  DOUTORADO
  OUTRO
}

enum StatusAmizade {
  PENDENTE
  ATIVO
  RECUSADO
}

model Usuario {
  id       String  @id @default(cuid())
  nome     String
  nickname String? @unique
  email    String  @unique
  senha    String

  perfil  PerfilUsuario
  status  StatusUsuario @default(ATIVO)
  visivel Boolean       @default(true)

  instituicao      String?
  curso            String?
  semestre         String?
  estado           String?
  cidade           String?
  nacionalidade    String?
  dataNascimento   DateTime?
  nivelEducacional NivelEducacional?

  departamento String?
  siape        String? @unique

  aprovadoPorId String?
  aprovadoEm    DateTime?

  refreshTokens          RefreshToken[]
  tokensRedefinicaoSenha TokenRedefinicaoSenha[]

  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt
  excluidoEm        DateTime?
  amizadesEnviadas  Amizade[] @relation("usuario_origem")
  amizadesRecebidas Amizade[] @relation("usuario_destino")

  @@map("usuarios")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiraEm  DateTime

  revogadoEm DateTime?
  criadoEm   DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model TokenRedefinicaoSenha {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  expiraEm  DateTime

  usadoEm  DateTime?
  criadoEm DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_redefinicao_senha")
}

model Amizade {
  id String @id @default(cuid())

  usuarioOrigemId  String
  usuarioDestinoId String

  statusAmizade StatusAmizade @default(PENDENTE)

  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  excluidoEm   DateTime?

  usuarioOrigem  Usuario @relation(name: "usuario_origem", fields: [usuarioOrigemId], references: [id], onDelete: Cascade, map: "usuario_origem_fk")
  usuarioDestino Usuario @relation(name: "usuario_destino", fields: [usuarioDestinoId], references: [id], onDelete: Cascade, map: "usuario_destino_fk")

  @@unique([usuarioOrigemId, usuarioDestinoId])
  @@map("amizades")
}
